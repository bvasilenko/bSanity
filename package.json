{
  "name": "@booga/bsanity",
  "version": "0.1.0",
  "description": "Sanity v3 plugin embedding the b-suite discipline runtime into the Studio authoring UI.",
  "license": "MIT",
  "repository": "github:bvasilenko/bSanity",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./proxy": {
      "types": "./dist/runtime/proxy.d.ts",
      "import": "./dist/runtime/proxy.js",
      "require": "./dist/runtime/proxy.cjs"
    },
    "./function": {
      "types": "./dist/functions/b-sanity-binary-proxy.d.ts",
      "import": "./dist/functions/b-sanity-binary-proxy.js",
      "require": "./dist/functions/b-sanity-binary-proxy.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "sanity.blueprint.ts"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18",
    "sanity": "^3"
  },
  "peerDependenciesMeta": {
    "sanity": {
      "optional": false
    }
  },
  "dependencies": {
    "@sanity/functions": "^1.3.1",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@sanity/blueprints": "^0.20.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.32",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanity": "^3.99.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.15.1"
}
